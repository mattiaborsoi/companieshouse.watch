# Companies House API credentials
# Register at https://developer-specs.company-information.service.gov.uk
CH_REST_KEY=your_rest_api_key_here
CH_STREAM_KEY=your_stream_api_key_here

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://chwatch:chwatch@localhost:5432/chwatch
DATABASE_URL_SYNC=postgresql://chwatch:chwatch@localhost:5432/chwatch

# Redis (matches docker-compose defaults)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Internal only — never exposed publicly
ANTHROPIC_API_KEY=sk-ant-...
